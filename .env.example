# Samsung developer account (for generating certs)
SAMSUNG_ACCESS_TOKEN=
SAMSUNG_USER_ID=
TV_DUID=

# TV deployment
TV_IP=192.168.0.x

# Certificate passwords (used by deploy-tv.sh and sign-wgt.cjs)
CERT_AUTHOR_P12=certs/author.p12
CERT_DIST_P12=certs/distributor.p12
CERT_AUTHOR_PASSWORD=
CERT_DIST_PASSWORD=

# Optional server hardening
# If set, protected API calls must include x-streamvault-token or Bearer token.
STREAMVAULT_AUTH_TOKEN=
# Comma-separated extra hosts allowed for /api/proxy, in addition to the configured Xtream host.
STREAMVAULT_PROXY_ALLOWED_HOSTS=
# Comma-separated explicit CORS origins. Leave empty for LAN-friendly default.
STREAMVAULT_ALLOWED_ORIGINS=
